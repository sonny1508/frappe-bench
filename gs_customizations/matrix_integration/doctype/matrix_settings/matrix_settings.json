 "fields": [
  {
   "fieldname": "bot_configuration_section",
   "fieldtype": "Section Break",
   "label": "Bot Configuration"
  },
  {
   "default": "0",
   "fieldname": "enabled",
   "fieldtype": "Check",
   "label": "Enable Matrix Integration"
  },
  {
   "fieldname": "homeserver_url",
   "fieldtype": "Data",
   "label": "Homeserver URL",
   "description": "e.g. https://matrix.glenda-studio-chat.com",
   "mandatory_depends_on": "eval:doc.enabled"
  },
  {
   "fieldname": "column_break_bot",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "bot_user_id",
   "fieldtype": "Data",
   "label": "Bot Matrix User ID",
   "description": "e.g. @gs.bot:matrix.glenda-studio-chat.com",
   "mandatory_depends_on": "eval:doc.enabled"
  },
  {
   "fieldname": "bot_access_token",
   "fieldtype": "Password",
   "label": "Bot Access Token",
   "mandatory_depends_on": "eval:doc.enabled",
   "description": "Long-lived token from MAS admin or Synapse admin API"
  },
  {
   "fieldname": "bot_display_name",
   "fieldtype": "Data",
   "label": "Bot Display Name"
  },
  {
   "default": "0",
   "fieldname": "bot_is_admin",
   "fieldtype": "Check",
   "label": "Bot Has Synapse Admin Privileges",
   "description": "Enable to use Synapse admin API for force-joining users to rooms"
  },
  {
   "fieldname": "room_provisioning_section",
   "fieldtype": "Section Break",
   "label": "Room Provisioning"
  },
  {
   "default": "0",
   "fieldname": "auto_provision_rooms",
   "fieldtype": "Check",
   "label": "Auto-Provision DM Rooms on Employee Update",
   "description": "Automatically create a DM room when an Employee's linked User has a username"
  },
  {
   "fieldname": "dm_rooms_section",
   "fieldtype": "Section Break",
   "label": "DM Rooms"
  },
  {
   "fieldname": "dm_rooms",
   "fieldtype": "Table",
   "label": "DM Rooms",
   "options": "Matrix DM Room"
  },
  {
   "fieldname": "group_rooms_section",
   "fieldtype": "Section Break",
   "label": "Group Rooms"
  },
  {
   "fieldname": "group_rooms",
   "fieldtype": "Table",
   "label": "Group Rooms",
   "options": "Matrix Group Room"
  },
  {
   "fieldname": "development_section",
   "fieldtype": "Section Break",
   "label": "Development / Testing",
   "collapsible": 1
  },
  {
   "fieldname": "test_message",
   "fieldtype": "Small Text",
   "label": "Test Message"
  },
  {
   "fieldname": "column_break_dev",
   "fieldtype": "Column Break"
  },
  {
   "default": "DM",
   "fieldname": "test_target_type",
   "fieldtype": "Select",
   "label": "Send To",
   "options": "DM\nGroup"
  },
  {
   "depends_on": "eval:doc.test_target_type == 'DM'",
   "fieldname": "test_dm_username",
   "fieldtype": "Data",
   "label": "DM Username",
   "description": "Username from the DM Rooms table"
  },
  {
   "depends_on": "eval:doc.test_target_type == 'Group'",
   "fieldname": "test_group_room",
   "fieldtype": "Data",
   "label": "Group Room Name",
   "description": "Room name from the Group Rooms table"
  }
 ],
